{
  "name": "llm-cache-proxy",
  "version": "1.0.0",
  "description": "Local-only, zero-dependency byte-exact caching reverse proxy for the Anthropic Messages API. Replays cached responses with no upstream call on exact-match repeats.",
  "type": "module",
  "main": "proxy-a.mjs",
  "bin": { "llm-cache-proxy": "proxy-a.mjs" },
  "scripts": {
    "start": "node proxy-a.mjs",
    "on": "./cachectl-a.sh on",
    "off": "./cachectl-a.sh off",
    "stop": "./cachectl-a.sh stop",
    "stats": "./cachectl-a.sh stats",
    "check": "node --check proxy-a.mjs && node --check test-fidelity.mjs",
    "test": "node test-fidelity.mjs"
  },
  "engines": { "node": ">=18" },
  "license": "MIT",
  "author": "Mitch Hudson <mitchphudson@gmail.com>",
  "repository": { "type": "git", "url": "https://github.com/mithudso/llm-cache-proxy.git" },
  "keywords": ["anthropic", "claude", "llm", "cache", "proxy", "token-savings", "sse", "tool-use"]
}
