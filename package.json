{
  "name": "llm-cache-proxy",
  "version": "2.0.4",
  "files": [
    "proxy-a.mjs",
    "cachectl-a.sh",
    "cache-explorer.mjs",
    "cli.mjs",
    "bench.py",
    "test-fidelity.mjs",
    "docs/",
    "USAGE.md",
    "README.md",
    "LICENSE"
  ],
  "description": "Local-only, zero-dependency byte-exact caching reverse proxy for the Anthropic Messages API. Replays cached responses with no upstream call on exact-match repeats.",
  "type": "module",
  "main": "proxy-a.mjs",
  "bin": {
    "llm-cache-proxy": "cli.mjs"
  },
  "scripts": {
    "start": "node proxy-a.mjs",
    "on": "./cachectl-a.sh on",
    "off": "./cachectl-a.sh off",
    "stop": "./cachectl-a.sh stop",
    "stats": "./cachectl-a.sh stats",
    "status": "./cachectl-a.sh status",
    "monitor": "./cachectl-a.sh monitor",
    "explore": "./cachectl-a.sh explore",
    "check": "node --check proxy-a.mjs && node --check cli.mjs && node --check cache-explorer.mjs && node --check test-fidelity.mjs",
    "test": "node --test --experimental-test-coverage --test-coverage-include=proxy-a.mjs --test-coverage-lines=100 --test-coverage-functions=100 --test-coverage-branches=99 'proxy*.test.mjs'",
    "test:fidelity": "node test-fidelity.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "Mitch Hudson <mitchphudson@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/mithudso/llm-cache-proxy.git"
  },
  "keywords": [
    "anthropic",
    "claude",
    "llm",
    "cache",
    "proxy",
    "token-savings",
    "sse",
    "tool-use"
  ]
}
